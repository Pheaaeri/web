                    <!-- ทำเลือกชื่อผู้ใช้งาน -->
                    <div class="form-group row">
                        <label class="col-sm-4 col-form-label">ผู้อนุมัติ</label>
                        <div class="col-sm-8">
                            <select type="text" class="form-control" id="approverSelect" name="ผู้อนุมัติ"
                                required="required">
                                <option value="นายเวียง อากรชี">นายเวียง อากรชี (ผอ.)</option>
                                <!-- ปฏิบัติราชการแทน -->
                                <!--  <option value="นายอนุชิต ฉ่ำสิงห์">นายอนุชิต ฉ่ำสิงห์</option> 
                                <option value="ป-นางสาวปรีดาวรรณ ไชยศรีชลธาร">นางสาวปรีดาวรรณ
                                    ไชยศรีชลธาร (ปฏิบัติราชการแทน)</option>
                                <option value="ป-นายปรีชา อานันท์รัตนกุล">นายปรีชา อานันท์รัตนกุล (ปฏิบัติราชการแทน)
                                </option>
                                <option value="ป-นายจิรวัสส์ เจียตระกูล">นายจิรวัสส์ เจียตระกูล (ปฏิบัติราชการแทน) 
                                </option>
                                <option value="ป-นายปริญญวัฒน์ อยู่ทองอินทร์">นายปริญญวัฒน์
                                    อยู่ทองอินทร์ (ปฏิบัติราชการแทน)</option>
                                <option value="ป-นายคชธร อ่างบุญพงษ์">นายคชธร อ่างบุญพงษ์ (ปฏิบัติราชการแทน)</option>
                                <option value="ป-นายณัฐสิทธิ์ อยู่เย็น">นายณัฐสิทธิ์ อยู่เย็น (ปฏิบัติราชการแทน)
                                </option> 
                                <option value="ป-นายสุรชาติ ระย้าทอง">สุรชาติ ระย้าทอง (ปฏิบัติราชการแทน)</option> -->
                                <!-- รักษาการแทน -->
                                <option value="ร-นายปรีชา อานันท์รัตนกุล">นายปรีชา อานันท์รัตนกุล (รักษาราชการแทน)
                                </option>
                                <option value="ร-นางสาวปรีดาวรรณ ไชยศรีชลธาร">นางสาวปรีดาวรรณ ไชยศรีชลธาร
                                    (รักษาราชการแทน)
                                </option>
                                <option value="ร-นายจิรวัสส์ เจียตระกูล">นายจิรวัสส์ เจียตระกูล (รักษาราชการแทน)
                                </option>
                                <option value="ร-นายปริญญวัฒน์ อยู่ทองอินทร์">นายปริญญวัฒน์ อยู่ทองอินทร์
                                    (รักษาราชการแทน)
                                </option>
                                <option value="ร-นายคชธร อ่างบุญพงษ์">นายคชธร อ่างบุญพงษ์ (รักษาราชการแทน)</option>
                                <option value="ร-นายณัฐสิทธิ์ อยู่เย็น">นายณัฐสิทธิ์ อยู่เย็น (รักษาราชการแทน)</option>
                                <!-- <option value="ร-นายสุรชาติ ระย้าทอง">สุรชาติ ระย้าทอง (รักษาการแทน)</option> -->
                                <!-- <option value="นายวุฒิพล จันทร์สระคู">นายวุฒิพล จันทร์สระคู(ผู้อำนวยการสถาบันวิจัยเกษตรวิศวกรรม)</option> -->
                            </select>
